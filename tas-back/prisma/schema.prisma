generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  name          String?
  role          String   @default("user")
  createdAt     DateTime @default(now())
  projects      Project[] @relation("OwnerProjects")

  contributions Contribution[]
  notifications         Notification[]
}

enum ProjectStatus {
  PENDING
  APPROVED
  REJECTED
}

model Tier {
  id          Int    @id @default(autoincrement())
  amount      Float
  benefit     String

  projectId   Int
  project     Project @relation(fields: [projectId], references: [id])
}


model Project {
  id                     Int       @id @default(autoincrement())
  title                  String
  resume                  String
  description            String?
  domain                 String?

  status    ProjectStatus @default(PENDING)

  complexity             Complexity @default(MEDIUM)
  teamSize               Int?
  deadLine               DateTime
  durationMonths         Int?
  budget                 Float?
  studentGpaAvg          Float?
  supervisorExperience   Int?
  hasDataset             Boolean?

  priorSimilarProjects   Int?
  milestonesCompleted    Int?

  successLabel           Boolean?

  // Nuevos Inputs Estudiantiles/Objetivos
  trlLevel               Int        @default(1)
  hasPatents             Boolean    @default(false)
  hasVideoPitch          Boolean    @default(false)
  
  // Inputs existentes para heurística y UI
  hasTechnicalDoc        Boolean    @default(false)
  hasMarketStudy         Boolean    @default(false)
  hasMonetizationModel   Boolean    @default(false)
  sector                 Int        @default(5)
  hasDirectCompetitors   Boolean    @default(false)

  // Nuevos Outputs del Modelo de ML y Análisis
  projectedRaisedAmount  Float?
  feasibilityIndex       Float?
  transparencyIndex      Float?
  communityValidationScore Float?

  successScore           Float?

  ownerId                Int
  owner                  User       @relation("OwnerProjects", fields: [ownerId], references: [id])
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  allowFree              Boolean  @default(true)
  tiers                  Tier[]

  contributions         Contribution[]
  attachments            ProjectAttachment[]

  notifications         Notification[]
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  description String
  
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)
}

model ProjectAttachment {
  id          Int      @id @default(autoincrement())
  projectId   Int
  filename    String
  url         String
  mimeType    String
  size        Int
  description String?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Contribution {
  id        Int      @id @default(autoincrement())
  amount    Float
  createdAt DateTime @default(now())
    
  tierId    Int?

  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  paypalId    String?
}

enum Complexity {
  LOW
  MEDIUM
  HIGH
}