# Puerto donde correrá el servidor (opcional, el código asume 3001 por defecto)
PORT=3001

# URL de conexión a tu base de datos MySQL (requerido por Prisma)
# Formato: mysql://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE_DE_DATOS
DATABASE_URL="mysql://root:password@localhost:3306/tas_db"

# Palabra secreta para generar y firmar los tokens de sesión (JWT)
JWT_SECRET="escribe_aqui_un_texto_muy_largo_y_seguro"

# Credenciales de la API de PayPal (para el entorno de Sandbox/Pruebas)
PAYPAL_CLIENT_ID="tu_paypal_client_id"
PAYPAL_SECRET="tu_paypal_secret_key"